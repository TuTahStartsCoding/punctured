[gd_scene format=3 uid="uid://scoreboard_screen_v2"]

[ext_resource type="Script" path="res://Scripts/UI/ScoreboardScreen.gd" id="1_sb"]
[ext_resource type="LabelSettings" uid="uid://1cnb4418rr7" path="res://Art/Fonts/pixelized_label_large.tres" id="2_large"]
[ext_resource type="LabelSettings" uid="uid://da8inon5cmt2r" path="res://Art/Fonts/pixelized_label.tres" id="3_small"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_bg"]
bg_color = Color(0.05, 0.05, 0.12, 1.0)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_header"]
bg_color = Color(0.08, 0.08, 0.22, 0.95)
border_width_bottom = 2
border_color = Color(0.5, 0.5, 1.0, 1)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_summary"]
bg_color = Color(0.05, 0.15, 0.05, 0.90)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.3, 0.8, 0.3, 1)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_col_header"]
bg_color = Color(0.12, 0.12, 0.28, 0.95)
border_width_bottom = 1
border_color = Color(0.4, 0.4, 0.8, 0.8)

; ═══ ROOT Control (full-screen) ══════════════════════════
[node name="ScoreboardScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_sb")

; ═══ Dark background ══════════════════════════════════════
[node name="BgRect" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.12, 1.0)

; ═══ Centered panel ═══════════════════════════════════════
[node name="BG" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8

[node name="HeaderPanel" type="PanelContainer" parent="BG"]
layout_mode = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_header")

[node name="HeaderMargin" type="MarginContainer" parent="BG/HeaderPanel"]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 10

[node name="TitleLabel" type="Label" parent="BG/HeaderPanel/HeaderMargin"]
layout_mode = 2
text = "🏆  SCOREBOARD"
label_settings = ExtResource("2_large")
horizontal_alignment = 1

; ── Column headers ────────────────────────────────────────
[node name="ColHeaderPanel" type="PanelContainer" parent="BG"]
layout_mode = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_col_header")

[node name="ColMargin" type="MarginContainer" parent="BG/ColHeaderPanel"]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 3
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 3

[node name="ColHBox" type="HBoxContainer" parent="BG/ColHeaderPanel/ColMargin"]
layout_mode = 2

[node name="ColLevel" type="Label" parent="BG/ColHeaderPanel/ColMargin/ColHBox"]
custom_minimum_size = Vector2(138, 0)
layout_mode = 2
text = "ด่าน"
label_settings = ExtResource("3_small")
modulate = Color(0.8, 0.8, 1.0, 1)

[node name="ColStatus" type="Label" parent="BG/ColHeaderPanel/ColMargin/ColHBox"]
custom_minimum_size = Vector2(100, 0)
layout_mode = 2
text = "สถานะ"
label_settings = ExtResource("3_small")
horizontal_alignment = 1
modulate = Color(0.8, 0.8, 1.0, 1)

[node name="ColTime" type="Label" parent="BG/ColHeaderPanel/ColMargin/ColHBox"]
custom_minimum_size = Vector2(80, 0)
layout_mode = 2
text = "เวลา"
label_settings = ExtResource("3_small")
horizontal_alignment = 1
modulate = Color(0.8, 0.8, 1.0, 1)

[node name="ColCoin" type="Label" parent="BG/ColHeaderPanel/ColMargin/ColHBox"]
custom_minimum_size = Vector2(70, 0)
layout_mode = 2
text = "Coin"
label_settings = ExtResource("3_small")
horizontal_alignment = 2
modulate = Color(0.8, 0.8, 1.0, 1)

; ── Scrollable rows ───────────────────────────────────────
[node name="ScrollContainer" type="ScrollContainer" parent="BG"]
layout_mode = 2
size_flags_vertical = 3

[node name="RowsVBox" type="VBoxContainer" parent="BG/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 4

; ── Summary ───────────────────────────────────────────────
[node name="SummaryPanel" type="PanelContainer" parent="BG"]
layout_mode = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_summary")

[node name="SummaryMargin" type="MarginContainer" parent="BG/SummaryPanel"]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 10

[node name="SummaryLabel" type="Label" parent="BG/SummaryPanel/SummaryMargin"]
layout_mode = 2
text = "ผ่านด่าน: 0 / 0\nเวลารวม: 00:00\nCoin รวม: 0 🪙"
label_settings = ExtResource("3_small")
horizontal_alignment = 1

; ── Hint (inside VBox = safe layout) ─────────────────────
[node name="HintLabel" type="Label" parent="BG"]
layout_mode = 2
text = "R = เล่นใหม่   |   Esc = ออกเกม"
label_settings = ExtResource("3_small")
horizontal_alignment = 1
modulate = Color(0.7, 0.7, 0.7, 1)
